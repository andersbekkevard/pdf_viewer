[
    {
        "id": 1,
        "priority": 2,
        "action": { "type": "allow" },
        "condition": {
            "urlFilter": "_pdfvw=passthrough",
            "resourceTypes": ["main_frame"]
        }
    },
    {
        "id": 2,
        "priority": 1,
        "action": {
            "type": "redirect",
            "redirect": {
                "regexSubstitution": "http://localhost:7435/view?url=\\0"
            }
        },
        "condition": {
            "regexFilter": "^https?://.*\\.[Pp][Dd][Ff](?:\\?.*)?$",
            "resourceTypes": ["main_frame"],
            "excludedRequestDomains": ["localhost", "127.0.0.1"]
        }
    }
]
